# Copy to /etc/face-attendance.env (recommended) or project root as .env and load before start.
# systemd: EnvironmentFile=/etc/face-attendance.env

# --- Database ---
# SQLite (simplest: one file, no MySQL server)
DATABASE_TYPE=sqlite
SQLITE_PATH=attendance.db

# MySQL (uncomment and set DATABASE_TYPE=mysql if you use MySQL instead)
# DATABASE_TYPE=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_USER=attendance
# DATABASE_PASSWORD=change_me_strong_password
# DATABASE_NAME=attendance
# DATABASE_POOL_SIZE=10
# DATABASE_CONNECT_TIMEOUT=5

# --- HTTP ---
# Flask dev (python app.py) and Gunicorn both use FLASK_PORT (default 8002).
FLASK_PORT=8002
FLASK_DEBUG=false

# --- Browser API URL used when building the React app (no trailing slash on host) ---
# Example: http://203.0.113.50:8002/api  or  https://attendance.example.com/api
VITE_API_URL=http://YOUR_VM_IP_OR_DOMAIN:8002/api

# --- CORS: comma-separated origins. Leave unset to allow any origin (dev only).
# When using login cookies from a separate dev port (e.g. Vite on 3000), set:
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ORIGINS=https://attendance.example.com,http://YOUR_VM_IP:8002

# --- Web login (Flask session). First admin is created on first start if app_users is empty. ---
# AUTH_ENABLED=false   # legacy open API (not recommended)
# FLASK_SECRET_KEY=long-random-string
# WEB_ADMIN_USERNAME=admin
# WEB_ADMIN_PASSWORD=choose_a_strong_password
# Optional staff (role user): can use attendance + view records, no admin pages or record edits.
# WEB_STAFF_USERNAME=kiosk
# WEB_STAFF_PASSWORD=another_strong_password

# --- Geofence (browser GPS at login). Set center to your site (WGS84). ---
# GEOFENCE_ENABLED=true
# GEOFENCE_LATITUDE=12.9716
# GEOFENCE_LONGITUDE=77.5946
# GEOFENCE_RADIUS_METERS=200

# --- Face / training tuning (optional) ---
# FACE_CONFIDENCE_MIN=78
# FACE_REJECT_MULTIPLE=true
# TRAINING_MIN_IMAGES=18
