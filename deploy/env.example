# Copy to /etc/face-attendance.env (recommended) or project root as .env and load before start.
# systemd: EnvironmentFile=/etc/face-attendance.env

# --- Database ---
# SQLite (simplest: one file, no MySQL server)
DATABASE_TYPE=sqlite
SQLITE_PATH=attendance.db

# MySQL (uncomment and set DATABASE_TYPE=mysql if you use MySQL instead)
# DATABASE_TYPE=mysql
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3306
# DATABASE_USER=attendance
# DATABASE_PASSWORD=change_me_strong_password
# DATABASE_NAME=attendance
# DATABASE_POOL_SIZE=10
# DATABASE_CONNECT_TIMEOUT=5

# --- HTTP (Gunicorn binds here; put nginx in front on :443) ---
# FLASK_PORT is informational for docs; Gunicorn bind is set in the systemd unit.
# FLASK_HOST=0.0.0.0
FLASK_DEBUG=false

# --- Browser API URL used when building the React app (no trailing slash on host) ---
# Example: http://203.0.113.50:5000/api  or  https://attendance.example.com/api
VITE_API_URL=http://YOUR_VM_IP_OR_DOMAIN:5000/api

# --- CORS: comma-separated origins. Leave unset to allow any origin (dev only).
# CORS_ORIGINS=https://attendance.example.com,http://YOUR_VM_IP:5000

# --- Face / training tuning (optional) ---
# FACE_CONFIDENCE_MIN=78
# FACE_REJECT_MULTIPLE=true
# TRAINING_MIN_IMAGES=18
